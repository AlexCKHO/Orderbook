@OMS_HostAddress = http://localhost:5059

@placeReplayKey = place-replay-001
@placeConflictKey = place-conflict-001
@placeCorrelationId = corr-place-001

@cancelReplayKey = cancel-replay-001
@cancelConflictKey = cancel-conflict-001
@cancelCorrelationId = corr-cancel-001

### Health
GET {{OMS_HostAddress}}/health
Accept: application/json

### Ready
GET {{OMS_HostAddress}}/ready
Accept: application/json

### Place Order - valid
POST {{OMS_HostAddress}}/api/orders
Accept: application/json
Content-Type: application/json
X-Idempotency-Key: {{placeReplayKey}}
X-Correlation-ID: {{placeCorrelationId}}

{
  "accountId": 32,
  "symbol": "BTC-USD",
  "side": 1,
  "orderType": 1,
  "quantity": 100,
  "price": 50000
}

### Place Order - replay same payload same key
POST {{OMS_HostAddress}}/api/orders
Accept: application/json
Content-Type: application/json
X-Idempotency-Key: {{placeReplayKey}}
X-Correlation-ID: {{placeCorrelationId}}

{
  "accountId": 32,
  "symbol": "BTC-USD",
  "side": 1,
  "orderType": 1,
  "quantity": 100,
  "price": 50000
}

### Place Order - same key different payload -> should conflict
POST {{OMS_HostAddress}}/api/orders
Accept: application/json
Content-Type: application/json
X-Idempotency-Key: {{placeConflictKey}}
X-Correlation-ID: corr-place-conflict-001

{
  "accountId": 32,
  "symbol": "BTC-USD",
  "side": 1,
  "orderType": 1,
  "quantity": 100,
  "price": 50000
}

### Place Order - same key different payload second request -> should conflict
POST {{OMS_HostAddress}}/api/orders
Accept: application/json
Content-Type: application/json
X-Idempotency-Key: {{placeConflictKey}}
X-Correlation-ID: corr-place-conflict-001

{
  "accountId": 32,
  "symbol": "ETH-USD",
  "side": 1,
  "orderType": 1,
  "quantity": 100,
  "price": 50000
}

### Place Order - missing idempotency key -> should 400
POST {{OMS_HostAddress}}/api/orders
Accept: application/json
Content-Type: application/json

{
  "accountId": 32,
  "symbol": "BTC-USD",
  "side": 1,
  "orderType": 1,
  "quantity": 100,
  "price": 50000
}

