  "side": 1,
  "orderType": 1,
  "quantity": 100,
  "price": 50000
}

### Place Order - market order with price -> should 400
POST {{OMS_HostAddress}}/api/orders
Accept: application/json
Content-Type: application/json
X-Idempotency-Key: place-market-price-001
X-Correlation-ID: corr-place-market-price-001

{
  "accountId": 32,
  "symbol": "BTC-USD",
  "side": 1,
  "orderType": 2,
  "quantity": 100,
  "price": 50000
}

### Cancel Order - valid
POST {{OMS_HostAddress}}/api/orders/cancel
Accept: application/json
Content-Type: application/json
X-Idempotency-Key: {{cancelReplayKey}}
X-Correlation-ID: {{cancelCorrelationId}}

{
  "accountId": 32,
  "orderId": 137438953473
}

